{
  "cli": {
    "version": ">= 18.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_USE_DEV_CLIENT": "1"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "developmentClient": false,
      "environment": "production",
      "env": {
        "EXCLUDE_DEV_CLIENT": "1"
      },
      "android": {
        "buildType": "app-bundle"
      }
    },
    "preview": {
      "developmentClient": false,
      "environment": "preview",
      "distribution": "internal",
      "env": {
        "EXCLUDE_DEV_CLIENT": "1"
      },
      "android": {
        "buildType": "apk"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
