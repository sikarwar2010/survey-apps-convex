{
  "name": "survey-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start --lan",
    "start:tunnel": "expo start --tunnel",
    "start:localhost": "expo start --localhost",
    "reset-project": "node ./scripts/reset-project.js",
