{
  "name": "survey-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "node ./scripts/apply-ngrok-patches.mjs",
    "dev": "node ./scripts/dev-runner.mjs",
    "dev:clear": "node ./scripts/dev-runner.mjs --clear",
    "dev:tunnel": "node ./scripts/dev-runner.mjs --tunnel",
    "deploy": "node ./scripts/convex-deploy.mjs",
    "build:android": "expo run:android",
    "build:ios": "expo run:ios",
    "lint": "expo lint",
    "generate:logo": "node scripts/generate-logo-assets.mjs",
    "lockfile:eas": "node ./scripts/lockfile-eas.mjs",
    "verify:preview-native": "node ./scripts/verify-no-dev-client.mjs preview",
    "verify:eas-preview": "node ./scripts/verify-eas-preview.mjs",
    "eas:build:android": "eas build --platform android",
    "eas:build:android:preview": "npm run verify:eas-preview && eas build --platform android --profile preview --non-interactive",
    "eas:build:android:dev": "eas build --platform android --profile development --non-interactive",
    "eas:build:android:production": "npm run verify:eas-preview && eas build --platform android --profile production --non-interactive",
    "eas-build-pre-install": "node ./scripts/configure-eas-autolinking.mjs",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@clerk/expo": "^3.2.12",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.9.10",
    "@react-navigation/native": "^7.1.8",
    "convex": "^1.39.1",
    "expo": "^54.0.0",
    "expo-auth-session": "~7.0.11",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.23",
    "@expo/schema-utils": "^0.1.8",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.11",
    "nativewind": "^4.2.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "svix": "^1.93.0"
  },
  "optionalDependencies": {
    "utf-8-validate": "5.0.10",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@expo/ngrok": "4.1.3",
    "expo-dev-client": "~6.0.21",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "eas-cli": "^18.0.0",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "expo-docs-mcp": "^1.0.0",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "react-refresh": "^0.14.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.2"
  },
  "private": true,
  "expo": {
    "autolinking": {
      "android": {
        "exclude": [
          "expo-dev-client",
          "expo-dev-launcher",
          "expo-dev-menu",
          "expo-dev-menu-interface"
        ]
      },
      "ios": {
        "exclude": [
          "expo-dev-client",
          "expo-dev-launcher",
          "expo-dev-menu",
          "expo-dev-menu-interface"
        ]
      }
    }
  },
  "overrides": {
    "@expo/config": "~12.0.13",
    "@expo/config-plugins": "~54.0.4"
  }
}
